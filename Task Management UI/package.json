{
  "name": "task-management-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 4200",
    "build": "tsc -b && vite build",
    "lint": "eslint src/**/*.{js,mjs,cjs,ts,jsx,tsx} --max-warnings=0",
    "lint:fix": "eslint src/**/*.{js,mjs,cjs,ts,jsx,tsx} --fix",
    "pretty": "npx prettier src --check",
    "pretty:fix": "npm run pretty -- --write",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@mui/x-charts": "^8.14.0",
    "@mui/x-date-pickers": "^8.5.1",
    "axios": "^1.12.2",
    "dayjs": "^1.11.20",
    "i18next": "^23.15.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.0.2",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin-js": "^2.11.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-func": "^0.1.18",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^17.4.0",
    "husky": "^9.1.6",
    "identity-obj-proxy": "^3.0.0",
    "lint-staged": "^15.2.10",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.4.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts,jsx,tsx}": [
      "npm run lint",
      "npm run pretty"
    ]
  },
  "overrides": {
    "@eslint/plugin-kit": "0.4.0"
  }
}
